# Get a key at https://dev.runwayml.com/
RUNWAYML_API_SECRET=your_runway_api_key_here

# --- Vercel deployment only — leave unset for local dev ---
# These are normally injected automatically by Vercel when you connect a
# Blob store and a Redis store (Storage tab in the Vercel dashboard) to this
# project. You should not need to set them by hand except to test Blob/Redis
# mode locally.
#
# Blob store → Storage → Create → Blob
# BLOB_READ_WRITE_TOKEN=

# Redis store → Storage → Create → search "Redis" in the Marketplace tab
# (Vercel KV itself is deprecated; any Redis integration works — Upstash is
# the common one). Either naming below is supported:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
